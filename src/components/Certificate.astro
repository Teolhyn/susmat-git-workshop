---
import background from '../assets/background.svg';
interface CertificateProps {
  title: string,
  date_of_event: Date,
}

const { title, date_of_event } = Astro.props as CertificateProps;

---




<div id="container">
	<img id="background" src={background.src} alt="" fetchpriority="high" />
<div id="container" class="flex flex-col items-center font-montserrat">
  <h1 class="text-4xl">{title}</h1>
  <h2 class="text-sm">{date_of_event.toLocaleDateString("en-US", { month: "short", day: "2-digit", year: "numeric",})}</h2>
  <h3 class="mt-20 text-2xl mb-5">Participants:</h3>
  <slot />
</div>
</div>

<style>
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(100px);
	}
</style>
